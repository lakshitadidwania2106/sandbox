# Bifrost Security Plugin Test Environment Variables
# Copy this file to .env and fill in your actual values

# Required: OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Lakera Guard API Key for advanced prompt injection detection
# Get your key from: https://lakera.ai/
LAKERA_API_KEY=your-lakera-api-key-here

# Optional: Custom Bifrost URL (default: http://localhost:8080)
BIFROST_URL=http://localhost:8080

# Optional: Presidio URL (default: http://localhost:5000)
PRESIDIO_URL=http://localhost:5000
