{
  "$schema": "https://www.getbifrost.ai/schema",
  "governance": {},
  "client": {
    "initial_pool_size": 300,
    "enable_logging": true,
    "allowed_origins": [
      "*"
    ]
  },
  "providers": {
    "openai": {
      "keys": [
        {
          "name": "dummy-key",
          "value": "sk-dummy-key-not-used-with-mocker",
          "weight": 1,
          "models": [
            "gpt-3.5-turbo",
            "gpt-4",
            "gpt-4-turbo"
          ]
        }
      ]
    }
  },
  "plugins": [
    {
      "name": "mocker",
      "enabled": true,
      "config": {
        "enabled": true,
        "default_behavior": "passthrough",
        "global_latency": {
          "type": "uniform",
          "min": 10000000,
          "max": 50000000
        },
        "rules": [
          {
            "name": "catch-all-mock",
            "enabled": true,
            "priority": 1,
            "probability": 1.0,
            "conditions": {},
            "responses": [
              {
                "type": "success",
                "weight": 1.0,
                "content": {
                  "message": "This is a mock LLM response from Bifrost. The security plugin has validated this request and allowed it to proceed.",
                  "usage": {
                    "prompt_tokens": 10,
                    "completion_tokens": 25,
                    "total_tokens": 35
                  },
                  "finish_reason": "stop"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "name": "security",
      "enabled": true,
      "config": {
        "enable_policy_enforcement": true,
        "policy_path": "./policies",
        "enable_pii_detection": true,
        "redact_pii": true,
        "pii_entity_types": [
          "EMAIL_ADDRESS",
          "PHONE_NUMBER",
          "US_SSN",
          "CREDIT_CARD",
          "IP_ADDRESS",
          "PERSON",
          "LOCATION"
        ],
        "presidio_url": "http://localhost:5000",
        "enable_prompt_injection": true,
        "threat_score_threshold": 0.75,
        "lakera_api_key": "dummy",
        "enable_memory_poisoning": true,
        "max_memory_writes": 100,
        "memory_threat_threshold": 0.70,
        "enable_tool_validation": true,
        "allowed_tools": [
          "read_file",
          "list_directory",
          "search",
          "get_weather",
          "calculate"
        ],
        "denied_tools": [
          "execute_command",
          "delete_file",
          "write_database"
        ],
        "block_on_high_threat": true,
        "audit_log_path": "./logs/security-audit.log",
        "enable_http_hooks": true,
        "enable_llm_hooks": true,
        "enable_mcp_hooks": true
      }
    }
  ]
}